-- ==========================================
-- TAB 3: BRAINROT UTILITY
-- ==========================================
local BrainrotTab = Window:CreateTab("Brainrot Utility", 4483362458)

BrainrotTab:CreateSection("Brainrot Sound Finder")
BrainrotTab:CreateButton({
   Name = "Scan Game for Brainrot Audio",
   Callback = function()
       local found = false
       for _, v in pairs(game:GetDescendants()) do
           if v:IsA("Sound") then
               if string.find(v.Name:lower(), "skibidi") or string.find(v.Name:lower(), "sigma") or string.find(v.Name:lower(), "rizz") or string.find(v.Name:lower(), "hawk") then
                   Rayfield:Notify({
                      Name = "Brainrot Located!",
                      Content = "Found Audio: " .. v.Name .. " | ID: " .. string.match(v.SoundId, "%d+"),
                      Duration = 5,
                      Image = 4483362458,
                   })
                   found = true
               end
           end
       end
       if not found then
           Rayfield:Notify({
              Name = "Scan Complete",
              Content = "No obvious brainrot sound files found in Workspace.",
              Duration = 3,
              Image = 4483362458,
           })
       end
   end,
})

BrainrotTab:CreateSection("Brainrot Stealer Chat")
BrainrotTab:CreateButton({
   Name = "Steal Brainrot Phrase",
   Callback = function()
       local phrases = {
           "Skibidi Hawk Tuah Rizzler", 
           "Sigma Ohio Gyatt 100", 
           "Fanum Taxing your braincells", 
           "Baby Gronk Mewing Streak",
           "Look between H and L on your keyboard"
       }
       local randomPhrase = phrases[math.random(1, #phrases)]
       
       if game:GetService("TextChatService").ChatVersion == Enum.ChatVersion.TextChatService then
           game:GetService("TextChatService").TextChannels.RBXGeneral:SendAsync(randomPhrase)
       else
           game:GetService("ReplicatedStorage").DefaultChatSystemChatEvents.SayMessageRequest:FireServer(randomPhrase, "All")
       end
   end,
})
