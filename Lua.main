local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "Brainrot Multi-Hub",
   LoadingTitle = "Loading Systems...",
   LoadingSubtitle = "by Glitch Cyber",
   ConfigurationSaving = {
      Enabled = false
   },
   KeySystem = false
})

